generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== ENUMS =====
enum TrekDifficulty {
  EASY
  EASY_MODERATE
  MODERATE
  HARD
  VERY_HARD
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  TREK_LEADER
  USER
}

// ===== MODELS =====

model User {
  id          String  @id @default(cuid())
  email       String  @unique
  username    String  @unique
  password    String
  firstName   String?
  lastName    String?
  phoneNumber String?
  address     String?
  city        String?
  state       String?
  pincode     String?

  // Role-based access control
  role               UserRole  @default(USER)
  isActive           Boolean   @default(true)
  isLocked           Boolean   @default(false)
  isDenied           Boolean   @default(false)
  accountLockedUntil DateTime?

  // Security tracking
  lastLoginAt       DateTime?
  passwordChangedAt DateTime?

  // Password reset fields
  resetToken       String?
  resetTokenExpiry DateTime?

  // Relations
  bookings     Booking[]
  payments     Payment[]
  auditLogs    AuditLog[]
  failedLogins FailedLoginAttempt[]

  // Trek Leader Relations
  trekLeaderDepartures Departure[]        @relation("TrekLeader")
  trekLeaderPayouts    TrekLeaderPayout[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@index([createdAt])
}

model Trek {
  id              String         @id @default(cuid())
  slug            String         @unique
  name            String
  description     String         @db.Text
  longDescription String?        @db.Text
  state           String
  basePrice       Int // Price in INR (as paise to avoid floats)
  difficulty      TrekDifficulty
  duration        Int // days
  maxAltitude     Int? // meters
  distance        Float? // km
  bestSeason      String? // e.g., "Mar-May, Sep-Oct"

  // SEO & Media
  imageUrl     String?
  thumbnailUrl String?
  tags         String[] @default([])

  // Trek itinerary & details
  itinerary    String   @db.Text
  inclusions   String[] @default([])
  exclusions   String[] @default([])
  requirements String[] @default([])

  // ===== RICH CONTENT FIELDS (auto-populated by content pipeline) =====

  // Hero & About
  tagline   String? // One-line evocative tagline
  aboutText String? @db.Text // 250-400 word conversational about section

  // Structured Itinerary (JSON array of day objects)
  itineraryJson String? @db.Text

  // Difficulty Breakdown (JSON object)
  difficultyDetails String? @db.Text

  // Gear Checklist (JSON: { essential: [], doNotCarry: [] })
  gearChecklist String? @db.Text

  // FAQs (JSON array of { question, answer })
  faqsJson String? @db.Text

  // Best Time to Visit (JSON: month-by-month breakdown)
  bestTimeJson String? @db.Text

  // Getting There (plain text / markdown)
  gettingThere String? @db.Text

  // Permits & Regulations (plain text / markdown)
  permits String? @db.Text

  // Trek Metadata
  accommodationType String? // "Tent", "Homestay", "Lodge", "Mixed"
  pickupTime        String? // e.g., "6:00 AM from Manali"
  dropoffTime       String? // e.g., "4:00 PM at Manali"
  bestFor           String? // e.g., "18-45 years, moderate fitness"

  // SEO Fields
  seoTitle       String? // Max 60 chars
  seoDescription String? // Max 155 chars
  seoKeywords    String[] @default([])
  schemaMarkup   String?  @db.Text // JSON-LD schema markup

  // Content Management
  contentVerified    Boolean   @default(false)
  contentGeneratedAt DateTime?
  contentSources     String[]  @default([]) // Source URLs used

  // Relations
  departures Departure[]
  reviews    TrekReview[] @relation("reviews")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([difficulty])
  @@index([state])
  @@index([contentVerified])
}

model Departure {
  id     String @id @default(cuid())
  trekId String
  trek   Trek   @relation(fields: [trekId], references: [id], onDelete: Cascade)

  startDate      DateTime
  endDate        DateTime
  seatsAvailable Int // Current available seats
  totalSeats     Int // Total seats for this batch
  pricePerPerson Int // Specific price for this departure (INR in paise)

  // Trek Leader Assignment
  trekLeaderId   String?
  trekLeader     User?   @relation("TrekLeader", fields: [trekLeaderId], references: [id])
  trekLeaderName String? // Backup name if not assigned to user

  // Waitlist
  waitlistCount Int @default(0)
  maxWaitlist   Int @default(5)

  // Status tracking
  isCancelled        Boolean @default(false)
  cancellationReason String?

  // Status
  status String @default("OPEN") // OPEN, FULL, COMPLETED

  // Relations
  bookings          Booking[]
  trekLeaderPayouts TrekLeaderPayout[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([trekId, startDate]) // Prevent duplicate departures for same trek on same date
  @@index([trekId])
  @@index([startDate])
  @@index([isCancelled])
  @@index([status])
}

model Booking {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  departureId String
  departure   Departure @relation(fields: [departureId], references: [id], onDelete: Cascade)

  numberOfPeople Int           @default(1)
  totalAmount    Int // INR in paise (numberOfPeople * pricePerPerson)
  status         BookingStatus @default(PENDING)

  // Contact info at booking time (denormalized for history)
  contactName  String
  contactPhone String
  contactEmail String

  // Payment relation
  payment Payment?

  // Participant Tracking (minimal)
  // Medical Form
  medicalFormSubmitted Boolean   @default(false)
  medicalFormDate      DateTime?

  // ID Verification
  idVerified         Boolean   @default(false)
  idVerificationDate DateTime?
  idDocumentType     String? // Aadhar, Passport, DL

  // Waiver
  waiverSigned     Boolean   @default(false)
  waiverSignedDate DateTime?

  // Experience tracking
  isRepeatTrekker    Boolean @default(false)
  previousTreksCount Int     @default(0)

  // Emergency contact
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?

  // Audit trail
  cancellationReason String?
  cancelledAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, departureId]) // One booking per user per departure
  @@index([userId])
  @@index([departureId])
  @@index([status])
  @@index([createdAt])
}

model Payment {
  id        String  @id @default(cuid())
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount Int // INR in paise
  status PaymentStatus @default(PENDING)

  // Payment gateway integration
  paymentGateway  String // "razorpay", "stripe", etc.
  transactionId   String? @unique
  paymentIntentId String? // For idempotency

  // Payment Method
  paymentMethod String? // "razorpay", "upi", "bank_transfer"

  // Finance Tracking
  advanceAmount Int? // Advance paid
  balanceAmount Int? // Balance pending
  gstAmount     Int? // GST collected
  gstNumber     String? // Customer GST if available

  // Trek Leader Payout
  trekLeaderPayoutAmount Int?
  trekLeaderPayoutStatus String? // "PENDING", "PAID"

  // Metadata
  metadata     String? @db.Text // JSON string for additional data
  errorMessage String?

  // Refund tracking
  refundAmount        Int?
  refundedAt          DateTime?
  refundTransactionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([bookingId])
  @@index([status])
  @@index([createdAt])
}

model TrekReview {
  id     String @id @default(cuid())
  trekId String
  trek   Trek   @relation(name: "reviews", fields: [trekId], references: [id], onDelete: Cascade)

  userId  String
  rating  Int // 1-5
  title   String
  content String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trekId])
  @@index([rating])
}

model AuditLog {
  id         String @id @default(cuid())
  action     String // "BOOKING_CREATED", "PAYMENT_COMPLETED", "USER_ROLE_CHANGED", etc.
  entityType String // "BOOKING", "PAYMENT", "DEPARTURE", "USER", "ADMIN"
  entityId   String

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  changes     String? @db.Text // JSON diff of what changed
  metadata    String? @db.Text // Additional context (IP address, user agent, etc.)
  description String? // Human-readable description

  createdAt DateTime @default(now())

  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([userId])
  @@index([createdAt])
}

model Expedition {
  id              String         @id @default(cuid())
  slug            String         @unique
  name            String
  description     String         @db.Text
  longDescription String?        @db.Text
  state           String
  basePrice       Int // Price in INR (as paise)
  difficulty      TrekDifficulty
  duration        Int // days
  maxAltitude     Int? // meters
  distance        Float? // km
  bestSeason      String?

  // SEO & Media
  imageUrl     String?
  thumbnailUrl String?
  tags         String[] @default([])

  // Expedition details
  itinerary    String   @db.Text
  inclusions   String[] @default([])
  exclusions   String[] @default([])
  requirements String[] @default([])

  // Relations
  sessions ExpeditionSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([difficulty])
  @@index([state])
}

model ExpeditionSession {
  id           String     @id @default(cuid())
  expeditionId String
  expedition   Expedition @relation(fields: [expeditionId], references: [id], onDelete: Cascade)

  startDate      DateTime
  endDate        DateTime
  seatsAvailable Int
  totalSeats     Int
  pricePerPerson Int // INR in paise

  isCancelled        Boolean @default(false)
  cancellationReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([expeditionId, startDate])
  @@index([expeditionId])
  @@index([startDate])
}

model Course {
  id              String         @id @default(cuid())
  slug            String         @unique
  name            String
  description     String         @db.Text
  longDescription String?        @db.Text
  location        String
  price           Int // Price in INR (as paise)
  duration        Int // days
  difficulty      TrekDifficulty

  // SEO & Media
  imageUrl     String?
  thumbnailUrl String?
  tags         String[] @default([])

  // Course details
  curriculum   String   @db.Text
  inclusions   String[] @default([])
  exclusions   String[] @default([])
  requirements String[] @default([])
  instructor   String?

  // Relations
  sessions CourseSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([difficulty])
  @@index([location])
}

model CourseSession {
  id       String @id @default(cuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  startDate      DateTime
  endDate        DateTime
  seatsAvailable Int
  totalSeats     Int
  pricePerPerson Int // INR in paise

  isCancelled        Boolean @default(false)
  cancellationReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseId, startDate])
  @@index([courseId])
  @@index([startDate])
}

model FAQ {
  id       String  @id @default(cuid())
  question String
  answer   String  @db.Text
  category String? // e.g., "Trekking", "Courses", "General"
  order    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([order])
}

model FailedLoginAttempt {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  email     String // Also track by email for attempts with wrong credentials
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([email])
  @@index([ipAddress])
  @@index([createdAt])
}

model IPRestriction {
  id        String  @id @default(cuid())
  ipAddress String  @unique
  isAllowed Boolean @default(true) // true = whitelist, false = blacklist
  reason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ipAddress])
  @@index([isAllowed])
}

// ===== ADMIN PERMISSIONS SYSTEM =====

model AdminPermission {
  id          String           @id @default(cuid())
  permission  String           @unique // e.g., "VIEW_FINANCE", "EDIT_TREKS", "MANAGE_USERS"
  category    String // e.g., "DASHBOARD", "TREKS", "FINANCE", "MARKETING", "USERS"
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([category])
}

model RolePermission {
  id           String          @id @default(cuid())
  permissionId String
  permission   AdminPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         UserRole
  isEnabled    Boolean         @default(true) // Toggle ON/OFF

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([permissionId, role])
}

// ===== MARKETING METRICS =====

model MarketingMetric {
  id   String   @id @default(cuid())
  date DateTime @default(now())

  // Website Analytics
  websiteVisitors  Int   @default(0)
  websitePageViews Int   @default(0)
  conversionRate   Float @default(0)

  // Social Media
  instagramClicks      Int @default(0)
  instagramImpressions Int @default(0)

  // Bookings
  totalBookings          Int @default(0)
  referralBookings       Int @default(0)
  repeatCustomerBookings Int @default(0)

  // Top performing (stored as JSON)
  topTreks String? @db.Text // JSON array

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

// ===== TREK LEADER PAYOUT =====

model TrekLeaderPayout {
  id           String @id @default(cuid())
  trekLeaderId String
  trekLeader   User   @relation(fields: [trekLeaderId], references: [id])

  departureId String
  departure   Departure @relation(fields: [departureId], references: [id])

  amount Int // INR in paise
  status String @default("PENDING") // PENDING, PROCESSING, PAID, CANCELLED

  paymentMethod String?
  transactionId String?
  paidAt        DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trekLeaderId])
  @@index([status])
}
