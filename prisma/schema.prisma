generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String               @id @default(cuid())
  email              String               @unique
  username           String               @unique
  password           String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  address            String?
  city               String?
  firstName          String?
  lastName           String?
  phoneNumber        String?
  pincode            String?
  state              String?
  accountLockedUntil DateTime?
  isActive           Boolean              @default(true)
  isLocked           Boolean              @default(false)
  lastLoginAt        DateTime?
  passwordChangedAt  DateTime?
  role               UserRole             @default(USER)
  isDenied           Boolean              @default(false)
  resetToken         String?
  resetTokenExpiry   DateTime?
  auditLogs          AuditLog[]
  bookings           Booking[]
  Departure          Departure[]
  failedLogins       FailedLoginAttempt[]
  payments           Payment[]
  TrekLeaderPayout   TrekLeaderPayout[]

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@index([createdAt])
}

model Trek {
  id                 String         @id @default(cuid())
  slug               String         @unique
  name               String
  description        String
  longDescription    String?
  state              String
  basePrice          Int
  difficulty         TrekDifficulty
  duration           Int
  maxAltitude        Int?
  distance           Float?
  bestSeason         String?
  imageUrl           String?
  thumbnailUrl       String?
  tags               String[]       @default([])
  itinerary          String
  inclusions         String[]       @default([])
  exclusions         String[]       @default([])
  requirements       String[]       @default([])
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  aboutText          String?
  accommodationType  String?
  bestFor            String?
  bestTimeJson       String?
  contentGeneratedAt DateTime?
  contentSources     String[]       @default([])
  contentVerified    Boolean        @default(false)
  difficultyDetails  String?
  dropoffTime        String?
  faqsJson           String?
  gearChecklist      String?
  gettingThere       String?
  itineraryJson      String?
  permits            String?
  pickupTime         String?
  schemaMarkup       String?
  seoDescription     String?
  seoKeywords        String[]       @default([])
  seoTitle           String?
  tagline            String?
  departures         Departure[]
  reviews            TrekReview[]   @relation("reviews")

  @@index([slug])
  @@index([difficulty])
  @@index([state])
  @@index([contentVerified])
}

model Departure {
  id                 String             @id @default(cuid())
  trekId             String
  startDate          DateTime
  endDate            DateTime
  seatsAvailable     Int
  totalSeats         Int
  pricePerPerson     Int
  isCancelled        Boolean            @default(false)
  cancellationReason String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  maxWaitlist        Int                @default(5)
  status             String             @default("OPEN")
  trekLeaderId       String?
  trekLeaderName     String?
  waitlistCount      Int                @default(0)
  bookings           Booking[]
  trek               Trek               @relation(fields: [trekId], references: [id], onDelete: Cascade)
  User               User?              @relation(fields: [trekLeaderId], references: [id])
  TrekLeaderPayout   TrekLeaderPayout[]

  @@unique([trekId, startDate])
  @@index([trekId])
  @@index([startDate])
  @@index([isCancelled])
  @@index([status])
}

model Booking {
  id                       String        @id @default(cuid())
  userId                   String
  departureId              String
  numberOfPeople           Int           @default(1)
  totalAmount              Int
  status                   BookingStatus @default(PENDING)
  contactName              String
  contactPhone             String
  contactEmail             String
  cancellationReason       String?
  cancelledAt              DateTime?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  idDocumentType           String?
  idVerificationDate       DateTime?
  idVerified               Boolean       @default(false)
  isRepeatTrekker          Boolean       @default(false)
  medicalFormDate          DateTime?
  medicalFormSubmitted     Boolean       @default(false)
  previousTreksCount       Int           @default(0)
  waiverSigned             Boolean       @default(false)
  waiverSignedDate         DateTime?
  departure                Departure     @relation(fields: [departureId], references: [id], onDelete: Cascade)
  user                     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment                  Payment?

  @@unique([userId, departureId])
  @@index([userId])
  @@index([departureId])
  @@index([status])
  @@index([createdAt])
}

model Payment {
  id                     String        @id @default(cuid())
  bookingId              String        @unique
  userId                 String
  amount                 Int
  status                 PaymentStatus @default(PENDING)
  paymentGateway         String
  transactionId          String?       @unique
  paymentIntentId        String?
  metadata               String?
  errorMessage           String?
  refundAmount           Int?
  refundedAt             DateTime?
  refundTransactionId    String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  advanceAmount          Int?
  balanceAmount          Int?
  gstAmount              Int?
  gstNumber              String?
  paymentMethod          String?
  trekLeaderPayoutAmount Int?
  trekLeaderPayoutStatus String?
  booking                Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user                   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([bookingId])
  @@index([status])
  @@index([createdAt])
}

model TrekReview {
  id        String   @id @default(cuid())
  trekId    String
  userId    String
  rating    Int
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trek      Trek     @relation("reviews", fields: [trekId], references: [id], onDelete: Cascade)

  @@index([trekId])
  @@index([rating])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String
  userId      String?
  changes     String?
  metadata    String?
  createdAt   DateTime @default(now())
  description String?
  user        User?    @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([userId])
  @@index([createdAt])
}

model Expedition {
  id              String              @id @default(cuid())
  slug            String              @unique
  name            String
  description     String
  longDescription String?
  state           String
  basePrice       Int
  difficulty      TrekDifficulty
  duration        Int
  maxAltitude     Int?
  distance        Float?
  bestSeason      String?
  imageUrl        String?
  thumbnailUrl    String?
  tags            String[]            @default([])
  itinerary       String
  inclusions      String[]            @default([])
  exclusions      String[]            @default([])
  requirements    String[]            @default([])
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  sessions        ExpeditionSession[]

  @@index([slug])
  @@index([difficulty])
  @@index([state])
}

model ExpeditionSession {
  id                 String     @id @default(cuid())
  expeditionId       String
  startDate          DateTime
  endDate            DateTime
  seatsAvailable     Int
  totalSeats         Int
  pricePerPerson     Int
  isCancelled        Boolean    @default(false)
  cancellationReason String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  expedition         Expedition @relation(fields: [expeditionId], references: [id], onDelete: Cascade)

  @@unique([expeditionId, startDate])
  @@index([expeditionId])
  @@index([startDate])
}

model Course {
  id              String          @id @default(cuid())
  slug            String          @unique
  name            String
  description     String
  longDescription String?
  location        String
  price           Int
  duration        Int
  difficulty      TrekDifficulty
  imageUrl        String?
  thumbnailUrl    String?
  tags            String[]        @default([])
  curriculum      String
  inclusions      String[]        @default([])
  exclusions      String[]        @default([])
  requirements    String[]        @default([])
  instructor      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  sessions        CourseSession[]

  @@index([slug])
  @@index([difficulty])
  @@index([location])
}

model CourseSession {
  id                 String   @id @default(cuid())
  courseId           String
  startDate          DateTime
  endDate            DateTime
  seatsAvailable     Int
  totalSeats         Int
  pricePerPerson     Int
  isCancelled        Boolean  @default(false)
  cancellationReason String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  course             Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, startDate])
  @@index([courseId])
  @@index([startDate])
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([order])
}

model FailedLoginAttempt {
  id        String   @id @default(cuid())
  userId    String
  email     String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@index([ipAddress])
  @@index([createdAt])
}

model IPRestriction {
  id        String   @id @default(cuid())
  ipAddress String   @unique
  isAllowed Boolean  @default(true)
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ipAddress])
  @@index([isAllowed])
}

model AdminPermission {
  id             String           @id
  permission     String           @unique
  category       String
  description    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  RolePermission RolePermission[]

  @@index([category])
}

model MarketingMetric {
  id                     String   @id
  date                   DateTime @default(now())
  websiteVisitors        Int      @default(0)
  websitePageViews       Int      @default(0)
  conversionRate         Float    @default(0)
  instagramClicks        Int      @default(0)
  instagramImpressions   Int      @default(0)
  totalBookings          Int      @default(0)
  referralBookings       Int      @default(0)
  repeatCustomerBookings Int      @default(0)
  topTreks               String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime

  @@index([date])
}

model RolePermission {
  id              String          @id
  permissionId    String
  role            UserRole
  isEnabled       Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  AdminPermission AdminPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([permissionId, role])
}

model TrekLeaderPayout {
  id            String    @id
  trekLeaderId  String
  departureId   String
  amount        Int
  status        String    @default("PENDING")
  paymentMethod String?
  transactionId String?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  Departure     Departure @relation(fields: [departureId], references: [id])
  User          User      @relation(fields: [trekLeaderId], references: [id])

  @@index([status])
  @@index([trekLeaderId])
}

enum TrekDifficulty {
  EASY
  EASY_MODERATE
  MODERATE
  HARD
  VERY_HARD
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum UserRole {
  ADMIN
  MODERATOR
  USER
  SUPER_ADMIN
  TREK_LEADER
}
